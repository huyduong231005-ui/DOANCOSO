@model List<t.Areas.Admin.Models.ApartmentListVm>
@using t.Models.Entities
@{
    ViewData["Title"] = "Căn hộ";
    var pager = (t.Areas.Admin.Models.PageInfo)ViewBag.Pager;
    var regions = (List<Region>)ViewBag.Regions;
    var cats = (List<Category>)ViewBag.Categories;
    var buildings = (List<Building>)ViewBag.Buildings;
    var q = (string?)ViewBag.Q;
    var status = (ListingStatus?)ViewBag.Status;
    var occupancy = (ApartmentOccupancy?)ViewBag.Occupancy;
    var regionId = (int?)ViewBag.RegionId;
    var categoryId = (int?)ViewBag.CategoryId;
    var buildingId = (int?)ViewBag.BuildingId;
    string OccPill(ApartmentOccupancy o) => o switch
    {
        ApartmentOccupancy.Occupied => "pill pill-success",
        ApartmentOccupancy.Available => "pill pill-info",
        ApartmentOccupancy.Reserved => "pill pill-warning",
        ApartmentOccupancy.UnderMaintenance => "pill pill-danger",
        _ => "pill"
    };
    string Money(decimal v) => v >= 1_000_000 ? $"{v/1_000_000m:0.#}tr" : v.ToString("N0");
}

<section class="page-header">
    <div>
        <h1>Căn hộ</h1>
        <p class="subtitle">Quản lý danh sách căn hộ — @pager.TotalCount kết quả</p>
    </div>
    <div class="actions">
        <a class="btn btn-primary" asp-action="Create"><span class="material-symbols-outlined">add</span>Thêm căn hộ</a>
    </div>
</section>

<form method="get" class="filter-bar">
    <input type="search" name="q" value="@q" placeholder="Tìm theo tên, slug, địa chỉ..."
       data-suggest-url="@Url.Action("Suggest")" data-suggest-icon="apartment" />
    <select name="status">
        <option value="">— Trạng thái —</option>
        @foreach (var s in Enum.GetValues<ListingStatus>())
        {
            <option value="@((int)s)" selected="@(status == s)">@s.Vi()</option>
        }
    </select>
    <select name="occupancy">
        <option value="">— Tình trạng —</option>
        @foreach (var o in Enum.GetValues<ApartmentOccupancy>())
        {
            <option value="@((int)o)" selected="@(occupancy == o)">@o.Vi()</option>
        }
    </select>
    <select name="buildingId">
        <option value="">— Toà nhà —</option>
        @foreach (var b in buildings) { <option value="@b.Id" selected="@(buildingId == b.Id)">@b.Name</option> }
    </select>
    <select name="regionId">
        <option value="">— Khu vực —</option>
        @foreach (var r in regions) { <option value="@r.Id" selected="@(regionId == r.Id)">@r.Name</option> }
    </select>
    <select name="categoryId">
        <option value="">— Phân loại —</option>
        @foreach (var c in cats) { <option value="@c.Id" selected="@(categoryId == c.Id)">@c.Name</option> }
    </select>
    <button type="submit" class="btn btn-primary"><span class="material-symbols-outlined">filter_alt</span>Lọc</button>
    <a class="btn btn-ghost" asp-action="Index">Xoá lọc</a>
</form>

<div class="card">
    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Căn hộ</th><th>Toà / Tầng</th><th>Phân loại</th><th>Chủ căn</th>
                    <th class="num">Giá/tháng</th><th>Trạng thái</th><th>Tình trạng</th><th></th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="8"><div class="empty-state"><span class="material-symbols-outlined">apartment</span><h3>Không có căn hộ nào</h3><p>Thử bỏ bộ lọc hoặc tạo mới.</p></div></td></tr>
            }
            else
            {
                foreach (var a in Model)
                {
                    <tr data-href="@Url.Action("Details", new { id = a.Id })" title="Bấm để xem chi tiết">
                        <td>
                            <div class="hstack">
                                <img class="thumb" src="@(string.IsNullOrEmpty(a.CoverUrl) ? "/img/region-hcm.jpg" : a.CoverUrl)" alt="" onerror="this.style.visibility='hidden'" />
                                <div>
                                    <div class="row-title">@(a.UnitCode ?? "—") · @a.Title @(a.IsFeatured ? Html.Raw("<span class=\"pill pill-accent\" style=\"margin-left:.4rem;\">Nổi bật</span>") : null)</div>
                                    <div class="row-meta">@a.RegionName · @a.CreatedAt.ToString("dd/MM/yyyy")</div>
                                </div>
                            </div>
                        </td>
                        <td>@(a.BuildingName ?? "—")<div class="row-meta">@(a.FloorLabel ?? "—")</div></td>
                        <td>@a.CategoryName</td>
                        <td>@a.HostName</td>
                        <td class="num">@Money(a.Price)</td>
                        <td>
                            <form asp-action="ChangeStatus" method="post" class="quick-status-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@a.Id" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                <select name="status" onchange="this.form.requestSubmit()">
                                    @foreach (var s in Enum.GetValues<ListingStatus>())
                                    {
                                        <option value="@((int)s)" selected="@(a.Status == s)">@s.Vi()</option>
                                    }
                                </select>
                            </form>
                        </td>
                        <td><span class="@OccPill(a.Occupancy)">@a.Occupancy.Vi()</span></td>
                        <td class="actions-cell">
                            <a class="btn btn-ghost btn-sm" asp-action="Edit" asp-route-id="@a.Id" title="Sửa"><span class="material-symbols-outlined">edit</span></a>
                            <form asp-action="ToggleFeature" asp-route-id="@a.Id" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-ghost btn-sm" title="@(a.IsFeatured ? "Bỏ nổi bật" : "Đánh dấu nổi bật")">
                                    <span class="material-symbols-outlined">@(a.IsFeatured ? "star" : "star_outline")</span>
                                </button>
                            </form>
                            <form asp-action="Delete" asp-route-id="@a.Id" method="post" style="display:inline;" data-confirm="Xoá căn hộ này? Hành động này không thể hoàn tác." data-confirm-title="Xoá căn hộ" data-confirm-ok="Xoá">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-ghost btn-sm" title="Xoá"><span class="material-symbols-outlined">delete</span></button>
                            </form>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
    @await Html.PartialAsync("_Pagination", pager)
</div>
