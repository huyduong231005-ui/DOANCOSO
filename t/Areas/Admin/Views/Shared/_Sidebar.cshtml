@{
    var nav = (ViewData["ActiveNav"] as string ?? string.Empty).ToLowerInvariant();
    string Cls(string key) => nav == key ? "active" : string.Empty;
}
<aside class="admin-sidebar">
    <a class="brand" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
        <span class="brand-mark">L</span>
        <span class="brand-name">Luxe Admin</span>
    </a>

    <div>
        <div class="sidebar-section">Tổng quan</div>
        <nav>
            <a class="@Cls("dashboard")" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <span class="material-symbols-outlined">dashboard</span><span>Bảng điều khiển</span>
            </a>
        </nav>
    </div>

    <div>
        <div class="sidebar-section">Bất động sản</div>
        <nav>
            <a class="@Cls("buildings")" asp-area="Admin" asp-controller="Buildings" asp-action="Index">
                <span class="material-symbols-outlined">domain</span><span>Toà nhà</span>
            </a>
            <a class="@Cls("apartments")" asp-area="Admin" asp-controller="Apartments" asp-action="Index">
                <span class="material-symbols-outlined">apartment</span><span>Căn hộ</span>
            </a>
            <a class="@Cls("projects")" asp-area="Admin" asp-controller="Projects" asp-action="Index">
                <span class="material-symbols-outlined">location_city</span><span>Dự án</span>
            </a>
        </nav>
    </div>

    <div>
        <div class="sidebar-section">Vận hành</div>
        <nav>
            <a class="@Cls("leases")" asp-area="Admin" asp-controller="Leases" asp-action="Index">
                <span class="material-symbols-outlined">description</span><span>Hợp đồng</span>
            </a>
            <a class="@Cls("invoices")" asp-area="Admin" asp-controller="Invoices" asp-action="Index">
                <span class="material-symbols-outlined">receipt_long</span><span>Hoá đơn</span>
            </a>
            <a class="@Cls("payments")" asp-area="Admin" asp-controller="Payments" asp-action="Index">
                <span class="material-symbols-outlined">payments</span><span>Thanh toán</span>
            </a>
            <a class="@Cls("utilities")" asp-area="Admin" asp-controller="Utilities" asp-action="Index">
                <span class="material-symbols-outlined">bolt</span><span>Điện / Nước</span>
            </a>
            <a class="@Cls("maintenance")" asp-area="Admin" asp-controller="Maintenance" asp-action="Index">
                <span class="material-symbols-outlined">build</span><span>Bảo trì</span>
            </a>
            <a class="@Cls("viewings")" asp-area="Admin" asp-controller="Viewings" asp-action="Index">
                <span class="material-symbols-outlined">event</span><span>Lịch xem phòng</span>
            </a>
            <a class="@Cls("reviews")" asp-area="Admin" asp-controller="Reviews" asp-action="Index">
                <span class="material-symbols-outlined">reviews</span><span>Đánh giá</span>
            </a>
        </nav>
    </div>

    <div>
        <div class="sidebar-section">Báo cáo</div>
        <nav>
            <a class="@Cls("reports")" asp-area="Admin" asp-controller="Reports" asp-action="Occupancy">
                <span class="material-symbols-outlined">analytics</span><span>Báo cáo</span>
            </a>
        </nav>
    </div>

    <div>
        <div class="sidebar-section">Quản trị</div>
        <nav>
            <a class="@Cls("users")" asp-area="Admin" asp-controller="Users" asp-action="Index">
                <span class="material-symbols-outlined">group</span><span>Người dùng</span>
            </a>
            <a class="@Cls("roles")" asp-area="Admin" asp-controller="Roles" asp-action="Index">
                <span class="material-symbols-outlined">admin_panel_settings</span><span>Vai trò &amp; quyền</span>
            </a>
            <a class="@Cls("audit")" asp-area="Admin" asp-controller="AuditLogs" asp-action="Index">
                <span class="material-symbols-outlined">history</span><span>Nhật ký kiểm tra</span>
            </a>
        </nav>
    </div>

    <div class="sidebar-footer">
        <span>© Luxe Haven · @DateTime.Now.Year</span>
    </div>
</aside>
