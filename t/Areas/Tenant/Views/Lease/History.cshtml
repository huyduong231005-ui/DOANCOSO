@model List<t.Areas.Tenant.Models.TenantLeaseHistoryRow>
@using t.Models.Entities
@{
    ViewData["Title"] = "Lịch sử hợp đồng";
    var pager = (t.Areas.Admin.Models.PageInfo)ViewBag.Pager;
    var q = (string?)ViewBag.Q;
    var status = (LeaseStatus?)ViewBag.Status;
    string Money(decimal v) => v.ToString("N0");
    string Pill(LeaseStatus s) => s switch
    {
        LeaseStatus.Active => "pill pill-success",
        LeaseStatus.Pending => "pill pill-warning",
        LeaseStatus.Renewing => "pill pill-info",
        LeaseStatus.Expired => "pill pill-neutral",
        LeaseStatus.Terminated => "pill pill-danger",
        _ => "pill"
    };
}

<section class="page-header">
    <div>
        <h1>Lịch sử hợp đồng</h1>
        <p class="subtitle">@pager.TotalCount hợp đồng</p>
    </div>
    <div class="actions">
        <a class="btn btn-ghost" asp-action="Index"><span class="material-symbols-outlined">arrow_back</span>Hợp đồng hiện tại</a>
    </div>
</section>

<form method="get" class="filter-bar">
    <input type="search" name="q" value="@q" placeholder="Mã hợp đồng, căn hộ, toà nhà..." />
    <select name="status">
        <option value="">— Tất cả trạng thái —</option>
        @foreach (var s in Enum.GetValues<LeaseStatus>()) { <option value="@((int)s)" selected="@(status == s)">@s.Vi()</option> }
    </select>
    <button type="submit" class="btn btn-primary">Lọc</button>
    <a class="btn btn-ghost" asp-action="History">Xoá lọc</a>
</form>

<div class="card">
    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Mã</th>
                    <th>Căn / Toà</th>
                    <th>Thời hạn</th>
                    <th class="num">Tiền / tháng</th>
                    <th>Vai trò</th>
                    <th>Trạng thái</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="7"><div class="empty-state"><span class="material-symbols-outlined">history</span><h3>Không có hợp đồng nào</h3></div></td></tr>
            }
            else
            {
                foreach (var l in Model)
                {
                    <tr>
                        <td><a class="row-title" asp-action="Index" asp-route-id="@l.Id">@l.LeaseNumber</a></td>
                        <td><div>@l.ApartmentTitle</div><div class="row-meta">@(l.BuildingName ?? "—")</div></td>
                        <td class="text-muted no-wrap">@l.StartDate.ToString("dd/MM/yy") – @l.EndDate.ToString("dd/MM/yy")</td>
                        <td class="num">@Money(l.MonthlyRent)</td>
                        <td>
                            @if (l.IsCoTenant) { <span class="pill pill-neutral">Đồng thuê</span> }
                            else { <span class="pill pill-info">Khách chính</span> }
                        </td>
                        <td><span class="@Pill(l.Status)">@l.Status.Vi()</span></td>
                        <td class="actions-cell">
                            <a class="btn btn-ghost btn-sm" asp-action="Index" asp-route-id="@l.Id" title="Xem chi tiết"><span class="material-symbols-outlined">visibility</span></a>
                            <a class="btn btn-ghost btn-sm" asp-action="ContractPdf" asp-route-id="@l.Id" target="_blank" title="Tải PDF"><span class="material-symbols-outlined">picture_as_pdf</span></a>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
    @await Html.PartialAsync("/Areas/Admin/Views/Shared/_Pagination.cshtml", pager)
</div>
