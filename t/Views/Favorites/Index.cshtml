@model List<t.Models.Entities.Apartment>
@{
    ViewData["Title"] = "Yêu thích của tôi";
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<section class="rentals-shell">
    <div class="container mx-auto px-4 py-8">
        <div class="mb-6 flex items-center justify-between">
            <div>
                <h1 class="font-headline text-3xl font-semibold">Yêu thích của tôi</h1>
                <p class="text-on-surface-variant">@Model.Count căn hộ đã lưu</p>
            </div>
            <a asp-controller="Home" asp-action="Rentals" class="btn btn-ghost">Tìm thêm</a>
        </div>

        @if (!Model.Any())
        {
            <div class="rounded-2xl border border-outline-variant/70 bg-white px-6 py-16 text-center">
                <span class="material-symbols-outlined text-6xl text-on-surface-variant/40">favorite_border</span>
                <h3 class="mt-4 font-headline text-xl">Bạn chưa lưu căn hộ nào</h3>
                <p class="mt-2 text-on-surface-variant">Khi xem tin đăng, bấm vào biểu tượng trái tim để lưu lại.</p>
                <a asp-controller="Home" asp-action="Rentals" class="mt-4 inline-flex h-10 items-center rounded-lg bg-primary px-4 text-sm font-semibold text-on-primary">Khám phá tin đăng</a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
                @foreach (var apartment in Model)
                {
                    var coverImg = apartment.Images.FirstOrDefault(i => i.IsCover)?.Url
                                  ?? apartment.Images.OrderBy(i => i.SortOrder).Select(i => i.Url).FirstOrDefault()
                                  ?? "/img/rent-1.jpg";
                    <article class="overflow-hidden rounded-3xl border border-outline-variant/70 bg-white shadow-sm">
                        <a asp-controller="Home" asp-action="ApartmentDetail" asp-route-id="@apartment.Id" class="block">
                            <img src="@coverImg" alt="@apartment.Title" class="h-52 w-full object-cover" />
                        </a>
                        <div class="space-y-3 px-4 py-4">
                            <div class="flex items-start justify-between gap-3">
                                <div>
                                    <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-on-surface-variant">@apartment.Category?.Name</p>
                                    <h2 class="line-clamp-2 font-headline text-lg font-semibold">@apartment.Title</h2>
                                </div>
                                <form asp-controller="Favorites" asp-action="Toggle" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="apartmentId" value="@apartment.Id" />
                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                    <button type="submit" title="Bỏ yêu thích" class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-primary bg-primary/10 text-primary">
                                        <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">favorite</span>
                                    </button>
                                </form>
                            </div>
                            <p class="line-clamp-1 text-sm text-on-surface-variant">@apartment.Address</p>
                            <div class="grid grid-cols-2 gap-2 rounded-2xl bg-surface-container-low px-3 py-2 text-xs text-on-surface-variant">
                                <div>Diện tích: <strong class="text-on-background">@apartment.Area m²</strong></div>
                                <div>Phòng ngủ: <strong class="text-on-background">@apartment.Bedrooms</strong></div>
                            </div>
                            <div class="flex items-center justify-between">
                                <p class="text-sm font-semibold text-primary">@apartment.Price.ToString("N0") VND/tháng</p>
                                <a asp-controller="Home" asp-action="ApartmentDetail" asp-route-id="@apartment.Id" class="inline-flex h-9 items-center rounded-lg border border-primary px-3 text-xs font-semibold text-primary">Xem</a>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</section>
