@model List<t.Models.Entities.Apartment>
@{
    ViewData["Title"] = "Yêu thích của tôi";
    ViewData["BodyClass"] = "luxe-rentals";
    ViewData["ActiveNav"] = "favorites";
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<partial name="_LuxeTopbar" />

<main class="mx-auto w-full max-w-[1280px] px-4 pb-10 pt-24 sm:px-6 lg:px-8">
    <!-- Header Section -->
    <section class="rentals-fx d-1 rounded-3xl border border-outline-variant/60 bg-white/85 px-5 py-5 shadow-sm sm:px-6">
        <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
                <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-on-surface-variant">My Collection</p>
                <h1 class="font-headline text-2xl font-semibold text-primary sm:text-3xl">Yêu thích của tôi</h1>
            </div>
            <div class="rounded-xl bg-primary px-3 py-2 text-xs font-semibold text-white">
                Đang lưu <span data-favorite-count>@Model.Count</span> căn hộ
            </div>
        </div>
    </section>

    <!-- Content Section -->
    <div data-favorite-empty class="@(Model.Any() ? "hidden" : "") rentals-fx d-2 mt-6 rounded-3xl border border-outline-variant/60 bg-white/85 px-6 py-16 text-center shadow-sm">
        <span class="material-symbols-outlined text-6xl text-on-surface-variant/40">favorite_border</span>
        <h3 class="mt-4 font-headline text-xl font-semibold text-primary">Bạn chưa lưu căn hộ nào</h3>
        <p class="mt-2 text-on-surface-variant">Khi xem tin đăng, bấm vào biểu tượng trái tim để lưu lại.</p>
        <a asp-controller="Home" asp-action="Rentals" data-soft-nav="true" class="mt-6 inline-flex h-11 items-center rounded-xl bg-primary px-6 text-sm font-semibold text-white transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-primary/20">Khám phá tin đăng</a>
    </div>

    @if (Model.Any())
    {
        <section data-favorite-grid class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            @for (var i = 0; i < Model.Count; i++)
            {
                var apartment = Model[i];
                var coverImg = apartment.Images.FirstOrDefault(img => img.IsCover)?.Url
                              ?? apartment.Images.OrderBy(img => img.SortOrder).Select(img => img.Url).FirstOrDefault()
                              ?? "/img/rent-1.jpg";
                var fxClass = $"d-{(i % 8) + 1}";

                <div class="rentals-fx @fxClass h-full" data-favorite-card>
                    <article class="listing-card overflow-hidden rounded-3xl border border-outline-variant/70 bg-white shadow-sm h-full">
                        <a asp-controller="Home" asp-action="ApartmentDetail" asp-route-id="@apartment.Id" class="block" data-soft-nav="true">
                            <img src="@coverImg" alt="@apartment.Title" class="h-52 w-full object-cover" />
                        </a>

                        <div class="space-y-3 px-4 py-4">
                            <div class="flex items-start justify-between gap-3">
                                <div class="flex-1 min-w-0">
                                    <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-on-surface-variant">@apartment.Category?.Name</p>
                                    <h2 class="line-clamp-2 font-headline text-lg font-semibold text-on-background mt-0.5">@apartment.Title</h2>
                                </div>
                                <form asp-controller="Favorites" asp-action="Set" method="post" class="inline" data-favorite-form data-favorite-remove>
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="apartmentId" value="@apartment.Id" />
                                    <input type="hidden" name="shouldBeFavorite" value="false" />
                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                    <button type="submit" title="Bỏ yêu thích" data-favorite-button
                                            class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-primary bg-primary/10 text-primary transition-all duration-300 hover:scale-105">
                                        <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">favorite</span>
                                    </button>
                                </form>
                            </div>

                            <p class="line-clamp-1 text-sm text-on-surface-variant">@apartment.Address</p>

                            <div class="grid grid-cols-2 gap-2 rounded-2xl bg-surface-container-low px-3 py-2 text-xs text-on-surface-variant">
                                <div>Diện tích: <strong class="text-on-background">@apartment.Area m²</strong></div>
                                <div>Phòng ngủ: <strong class="text-on-background">@apartment.Bedrooms</strong></div>
                            </div>

                            <div class="flex items-center justify-between pt-1">
                                <p class="text-sm font-semibold text-primary">@apartment.Price.ToString("N0") VND/tháng</p>
                                <a asp-controller="Home" asp-action="ApartmentDetail" asp-route-id="@apartment.Id" data-soft-nav="true" class="inline-flex h-9 items-center rounded-lg border border-primary px-4 text-xs font-semibold text-primary transition-all duration-300 hover:bg-primary/5">Xem chi tiết</a>
                            </div>
                        </div>
                    </article>
                </div>
            }
        </section>
    }
</main>
