@model t.Models.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
    ViewData["BodyClass"] = "luxe-auth auth-forgot";
}

<main class="auth-layout">
    <section class="auth-visual auth-fx-left">
        <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAh00btx8k7z7TqmakmPvREicthFlmWJSpIptLfB-wtyWXO18vWNRXeq-Pd_mRKFZsByMevVUTzipgOFBIUrqGf109AG71NIrmX1vzNEduylrcdLwzsKWjnJaSkxVqOkojrEI84fxdBKLpm9qKNfZkvXdgvvw-Su27U13Mi5aUh8KnvzbA1rOgn0YJqVO4_mb8Jb_DVUSNrtyA9Jh4_z0xqpCxJd4OStDj3yGo263AgxRGOSAYrAhJUDQQofRfCqqc5_gJnTo7-VJhT" alt="Kiến trúc nội thất nhẹ nhàng" />
        <div class="auth-visual-content">
            <span class="auth-brand">Luxe Haven</span>
            <div>
                <h1 class="auth-visual-title">Khám phá sự tĩnh lặng trong từng không gian sống.</h1>
                <p class="auth-visual-subtitle">Nơi những giấc mơ về tổ ấm sang trọng và tinh tế trở thành hiện thực.</p>
            </div>
            <p class="auth-visual-subtitle">Bảo mật thông tin luôn là ưu tiên hàng đầu.</p>
        </div>
    </section>

    <section class="auth-form-side">
        <div class="auth-panel auth-fx-up">
            <div class="auth-mobile-brand">Luxe Haven</div>

            <header class="auth-header">
                <h2>Quên mật khẩu?</h2>
                <p>Nhập email của bạn để nhận mã khôi phục tài khoản.</p>
            </header>

            @if (TempData["ForgotSuccess"] is bool ok && ok)
            {
                <div class="auth-success">
                    Nếu email tồn tại trong hệ thống, mã khôi phục đã được gửi. Vui lòng kiểm tra hộp thư của bạn.
                </div>
            }

            <form asp-action="ForgotPassword" method="post" class="auth-form" novalidate>
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="auth-validation-summary"></div>

                <div class="auth-field">
                    <label asp-for="Email">Địa chỉ email</label>
                    <div class="auth-input-wrap">
                        <span class="material-symbols-outlined">mail</span>
                        <input asp-for="Email" class="auth-input with-icon" placeholder="ten@domain.com" />
                    </div>
                    <p class="auth-help">Vui lòng nhập đúng định dạng email đã đăng ký tài khoản.</p>
                    <span asp-validation-for="Email" class="auth-error"></span>
                </div>

                <button class="auth-primary-btn" type="submit">Gửi mã xác thực</button>
            </form>

            <a asp-controller="Home" asp-action="Login" data-soft-nav="true" class="auth-back-link">
                <span class="material-symbols-outlined">arrow_back</span>
                Quay lại đăng nhập
            </a>

            <p class="auth-page-note">
                © 2024 Luxe Haven Editorial. Hệ thống xác thực được thiết kế bảo mật nhiều lớp.
            </p>
        </div>
    </section>
</main>
