@model t.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    ViewData["BodyClass"] = "luxe-auth auth-login";
}

<main class="auth-layout">
    <section class="auth-visual auth-fx-left">
        <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuApxNRj6ncVwgl0FBDfvARjYIIz4pHVHbXEJiFtwSs6Ed49vAeRpupmQ7slehRKDQsZnd2F1mF31N384RJ9mM6UZjGv4rsdD0zAbOxHeoWYwiOb7AhuMh7AyY4jRlx8nqZIpmwP0rzfG9Mf_RjL_Eg7UXMRKjNRhC9vvykpleMgnIFeJnGRs8_BpJFvFp4FwqUppneK_pMleBuWdIE3jsmLgc9uGUvkpOG3wWaISkn1k9EAG4lk6LUfAipYbkZdCLQwXRlBYdHCOkM-" alt="Không gian nội thất cao cấp" />
        <div class="auth-visual-content">
            <span class="auth-brand">Luxe Haven</span>
            <div>
                <h1 class="auth-visual-title">Kiến tạo không gian sống thượng lưu.</h1>
                <p class="auth-visual-subtitle">Khám phá bộ sưu tập căn hộ và nhà ở được tuyển chọn kỹ lưỡng dành riêng cho bạn.</p>
            </div>
            <p class="auth-visual-subtitle">+2.000 khách hàng đã tin dùng</p>
        </div>
    </section>

    <section class="auth-form-side">
        <div class="auth-panel auth-fx-up">
            <div class="auth-mobile-brand">Luxe Haven</div>

            <header class="auth-header">
                <h2>Chào mừng trở lại</h2>
                <p>Đăng nhập để tiếp tục hành trình tìm kiếm ngôi nhà mơ ước của bạn.</p>
            </header>

            <div class="auth-social-grid">
                <button class="auth-social-btn" type="button">
                    <span class="material-symbols-outlined">public</span>
                    Google
                </button>
                <button class="auth-social-btn" type="button">
                    <span class="material-symbols-outlined">groups</span>
                    Facebook
                </button>
            </div>

            <div class="auth-divider">
                <span>Hoặc với email</span>
            </div>

            <form asp-action="Login" asp-route-returnUrl="@(ViewData["ReturnUrl"] as string)" method="post" class="auth-form" novalidate>
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="auth-validation-summary"></div>

                <div class="auth-field">
                    <label asp-for="Email">Địa chỉ email</label>
                    <input asp-for="Email" class="auth-input" placeholder="ten@domain.com" />
                    <p class="auth-help">Vui lòng nhập đúng định dạng email. Ví dụ: ten@domain.com</p>
                    <span asp-validation-for="Email" class="auth-error"></span>
                </div>

                <div class="auth-field">
                    <div class="auth-inline">
                        <label asp-for="Password">Mật khẩu</label>
                        <a asp-controller="Home" asp-action="ForgotPassword" data-soft-nav="true" class="auth-link">Quên mật khẩu?</a>
                    </div>
                    <div class="auth-input-wrap">
                        <input asp-for="Password" class="auth-input with-action" id="login-password" placeholder="Nhập mật khẩu" />
                        <button class="auth-input-action" type="button" data-password-toggle="login-password">
                            <span class="material-symbols-outlined">visibility</span>
                        </button>
                    </div>
                    <p class="auth-help">Mật khẩu phải có ít nhất 6 ký tự.</p>
                    <span asp-validation-for="Password" class="auth-error"></span>
                </div>

                <label class="auth-checkbox">
                    <input asp-for="RememberMe" />
                    <span>Ghi nhớ đăng nhập</span>
                </label>

                <button class="auth-primary-btn" type="submit">Đăng nhập</button>
            </form>

            <p class="auth-cta-text">
                Bạn chưa có tài khoản?
                <a asp-controller="Home" asp-action="Register" data-soft-nav="true">Đăng ký ngay</a>
            </p>

            <div class="auth-footer-links">
                <a href="#">Trợ giúp</a>
                <a href="#">Bảo mật</a>
                <a href="#">Điều khoản</a>
            </div>
        </div>
    </section>
</main>
