@model t.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
    ViewData["BodyClass"] = "luxe-auth auth-register";
}

<main class="auth-layout">
    <section class="auth-visual auth-fx-left">
        <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuCPCXYsdZlL83qTp610YMyYaSUeYpj8zGFw3AD5rdlTbE7Fp9ptybAx3HjcjLPlhNFucahSJp3SDJFapdc4qP_UkPHmJFnNonC-78hOkVxU3Q7C7ZwBiELok1IZs3SwVmCFAZMX42yjbdqDDG9AeIwX5Q7T-S1MhoJZGhAcocvaGx_rz6ocdYlk_dvCWCVSndBWLOVckMgb9KZhHbDLMQts-2RoN6Qi0e4JKj1fffXaacl3WOYQXo6Q-G8csCK_jXc4pYM-gnPkehXl" alt="Không gian sống cao cấp" />
        <div class="auth-visual-content">
            <span class="auth-brand">Luxe Haven</span>
            <div>
                <h1 class="auth-visual-title">Gia nhập cộng đồng sống tinh hoa.</h1>
                <p class="auth-visual-subtitle">Khám phá những không gian sống đẳng cấp với trải nghiệm tìm thuê được cá nhân hóa cho bạn.</p>
            </div>
            <p class="auth-visual-subtitle">© 2024 Luxe Haven Editorial</p>
        </div>
    </section>

    <section class="auth-form-side">
        <div class="auth-panel auth-fx-up">
            <div class="auth-mobile-brand">Luxe Haven</div>

            <header class="auth-header">
                <h2>Tạo tài khoản mới</h2>
                <p>Bắt đầu hành trình tìm kiếm tổ ấm mơ ước của bạn.</p>
            </header>

            <div class="auth-social-grid">
                <button class="auth-social-btn" type="button">
                    <span class="material-symbols-outlined">public</span>
                    Google
                </button>
                <button class="auth-social-btn" type="button">
                    <span class="material-symbols-outlined">groups</span>
                    Facebook
                </button>
            </div>

            <div class="auth-divider">
                <span>Hoặc sử dụng email</span>
            </div>

            <form asp-action="Register" method="post" class="auth-form" novalidate>
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="auth-validation-summary"></div>

                <div class="auth-field">
                    <label asp-for="FullName">Họ và tên</label>
                    <input asp-for="FullName" class="auth-input" placeholder="Nguyễn Văn A" />
                    <p class="auth-help">Họ và tên phải từ 2 đến 100 ký tự.</p>
                    <span asp-validation-for="FullName" class="auth-error"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Email">Địa chỉ email</label>
                    <input asp-for="Email" class="auth-input" placeholder="ten@domain.com" />
                    <p class="auth-help">Vui lòng nhập đúng định dạng email. Ví dụ: ten@domain.com</p>
                    <span asp-validation-for="Email" class="auth-error"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Phone">Số điện thoại</label>
                    <input asp-for="Phone" class="auth-input" placeholder="0901234567 hoặc +84901234567" />
                    <p class="auth-help">Có thể bỏ trống. Nếu nhập, số điện thoại phải đúng định dạng Việt Nam.</p>
                    <span asp-validation-for="Phone" class="auth-error"></span>
                </div>

                <div class="auth-social-grid">
                    <div class="auth-field">
                        <label asp-for="Password">Mật khẩu</label>
                        <div class="auth-input-wrap">
                            <input asp-for="Password" class="auth-input with-action" id="register-password" placeholder="Nhập mật khẩu" />
                            <button class="auth-input-action" type="button" data-password-toggle="register-password">
                                <span class="material-symbols-outlined">visibility</span>
                            </button>
                        </div>
                        <p class="auth-help">Mật khẩu phải có ít nhất 6 ký tự và chứa ít nhất 1 chữ số.</p>
                        <span asp-validation-for="Password" class="auth-error"></span>
                    </div>

                    <div class="auth-field">
                        <label asp-for="ConfirmPassword">Xác nhận mật khẩu</label>
                        <div class="auth-input-wrap">
                            <input asp-for="ConfirmPassword" class="auth-input with-action" id="register-confirm" placeholder="Nhập lại mật khẩu" />
                            <button class="auth-input-action" type="button" data-password-toggle="register-confirm">
                                <span class="material-symbols-outlined">visibility</span>
                            </button>
                        </div>
                        <p class="auth-help">Mật khẩu xác nhận phải giống mật khẩu đã nhập.</p>
                        <span asp-validation-for="ConfirmPassword" class="auth-error"></span>
                    </div>
                </div>

                <button class="auth-primary-btn" type="submit">Đăng ký ngay</button>
            </form>

            <p class="auth-cta-text">
                Bạn đã có tài khoản?
                <a asp-controller="Home" asp-action="Login" data-soft-nav="true">Đăng nhập ngay</a>
            </p>

            <p class="auth-page-note">
                Bằng cách đăng ký, bạn đồng ý với Điều khoản dịch vụ và Chính sách bảo mật của Luxe Haven.
            </p>
        </div>
    </section>
</main>
