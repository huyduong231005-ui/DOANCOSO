@model t.Models.ViewModels.ApartmentListPageViewModel
@using System.Globalization
@using t.Infrastructure.Geo
@{
    ViewData["BodyClass"] = "luxe-rentals";
    ViewData["ActiveNav"] = "rentals";
    var categories = ViewBag.Categories as IEnumerable<t.Models.Entities.Category> ?? Enumerable.Empty<t.Models.Entities.Category>();
    var amenities = ViewBag.Amenities as IEnumerable<t.Models.Entities.Amenity> ?? Enumerable.Empty<t.Models.Entities.Amenity>();
    var regions = ViewBag.Regions as IEnumerable<t.Models.Entities.Region> ?? Enumerable.Empty<t.Models.Entities.Region>();
    var isAuthenticated = User?.Identity?.IsAuthenticated == true;
    var returnUrl = Context.Request.Path + Context.Request.QueryString;

    var activeCategoryName = string.IsNullOrEmpty(Model.CategorySlug)
        ? null
        : categories.FirstOrDefault(c => c.Slug == Model.CategorySlug)?.Name;
    var pageHeading = activeCategoryName ?? "Danh sách căn hộ cho thuê";
    ViewData["Title"] = activeCategoryName ?? "Thuê căn hộ";

    var categoriesList = categories.ToList();
    var amenitiesList = amenities.ToList();
    var quickAmenities = amenitiesList.Take(6).ToList();
    var advancedAmenities = amenitiesList.Skip(6).ToList();
    var selectedCategoryIds = Model.CategoryIds ?? new List<int>();
    var selectedAmenityIds = Model.AmenityIds ?? new List<int>();

    string BuildFilterUrl(Action<Microsoft.AspNetCore.Routing.RouteValueDictionary> mutate)
    {
        var routeValues = Model.Search.ToRouteValues(page: 1, clearPendingSave: true);
        routeValues["Page"] = null;
        mutate(routeValues);
        return Url.Action("Rentals", routeValues) ?? "#";
    }

    string FormatCompactPrice(decimal? value)
    {
        if (!value.HasValue)
        {
            return string.Empty;
        }

        return value.Value >= 1_000_000m
            ? $"{value.Value / 1_000_000m:0.#}tr"
            : value.Value.ToString("N0", CultureInfo.InvariantCulture);
    }

    string FormatRange(string prefix, object? min, object? max)
    {
        if (min is null && max is null)
        {
            return string.Empty;
        }

        return min is not null && max is not null
            ? $"{prefix}: {min} - {max}"
            : min is not null
                ? $"{prefix}: từ {min}"
                : $"{prefix}: đến {max}";
    }

    int? LeaseDisplayValue(int? months) =>
        months.HasValue && months.Value >= 12 && months.Value % 12 == 0
            ? months.Value / 12
            : months;

    string LeaseDisplayUnit(int? months) =>
        months.HasValue && months.Value >= 12 && months.Value % 12 == 0
            ? "years"
            : "months";

    string FormatCoordinate(double? value) =>
        value.HasValue
            ? value.Value.ToString(CultureInfo.InvariantCulture)
            : string.Empty;

    var activeFilterChips = new List<(string Label, string Url)>();
    if (!string.IsNullOrEmpty(Model.RegionSlug))
    {
        var regionName = regions.FirstOrDefault(region => region.Slug == Model.RegionSlug)?.Name ?? Model.RegionSlug;
        activeFilterChips.Add(($"Khu vực: {regionName}", BuildFilterUrl(route => route["Region"] = null)));
    }
    if (Model.MinPrice.HasValue || Model.MaxPrice.HasValue)
    {
        var minPriceLabel = Model.MinPrice.HasValue ? FormatCompactPrice(Model.MinPrice) : null;
        var maxPriceLabel = Model.MaxPrice.HasValue ? FormatCompactPrice(Model.MaxPrice) : null;
        activeFilterChips.Add((FormatRange("Giá", minPriceLabel, maxPriceLabel), BuildFilterUrl(route =>
        {
            route["MinPrice"] = null;
            route["MaxPrice"] = null;
        })));
    }
    if (Model.MinArea.HasValue || Model.MaxArea.HasValue)
    {
        activeFilterChips.Add((FormatRange("Diện tích", Model.MinArea, Model.MaxArea), BuildFilterUrl(route =>
        {
            route["MinArea"] = null;
            route["MaxArea"] = null;
        })));
    }
    if (Model.Search.MinBedrooms.HasValue)
    {
        activeFilterChips.Add(($"Từ {Model.Search.MinBedrooms} phòng ngủ", BuildFilterUrl(route => route["MinBedrooms"] = null)));
    }
    foreach (var category in categoriesList.Where(category => selectedCategoryIds.Contains(category.Id)))
    {
        activeFilterChips.Add(($"Loại: {category.Name}", BuildFilterUrl(route => route["CategoryIds"] = selectedCategoryIds.Where(id => id != category.Id).ToList())));
    }
    foreach (var amenity in amenitiesList.Where(amenity => selectedAmenityIds.Contains(amenity.Id)))
    {
        activeFilterChips.Add(($"Tiện ích: {amenity.Name}", BuildFilterUrl(route => route["AmenityIds"] = selectedAmenityIds.Where(id => id != amenity.Id).ToList())));
    }
}

<partial name="_LuxeTopbar" />

<main class="mx-auto w-full max-w-[1280px] px-4 pb-10 pt-24 sm:px-6 lg:px-8">
    <div class="rentals-page-shell">
    <aside class="rentals-filter-sidebar rentals-fx d-1 rounded-3xl border border-outline-variant/60 bg-white/85 px-5 py-5 shadow-sm sm:px-6" data-rentals-filter-sidebar>
        <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
                <h1 class="font-headline text-2xl font-semibold text-primary sm:text-3xl">@pageHeading</h1>
            </div>
            <div class="rounded-xl bg-primary px-3 py-2 text-xs font-semibold text-white">
                Tìm thấy @Model.TotalCount kết quả
            </div>
        </div>

        @if (activeFilterChips.Count > 0)
        {
            <div class="rentals-active-filters" data-active-filter-chips>
                @foreach (var chip in activeFilterChips)
                {
                    <a href="@chip.Url" class="rentals-active-filter-chip" data-active-filter-chip>
                        <span>@chip.Label</span>
                        <span class="material-symbols-outlined text-sm" aria-hidden="true">close</span>
                    </a>
                }
            </div>
        }

        <form asp-action="Rentals" method="get" id="rentals-filter-form" class="mt-4 grid gap-3">
            @if (!string.IsNullOrEmpty(Model.CategorySlug))
            {
                <input type="hidden" name="category" value="@Model.CategorySlug" />
            }
            @if (Model.IsNearbySort)
            {
                <input type="hidden" name="latitude" value="@Model.Latitude!.Value.ToString(CultureInfo.InvariantCulture)" />
                <input type="hidden" name="longitude" value="@Model.Longitude!.Value.ToString(CultureInfo.InvariantCulture)" />
            }
            <label class="block text-xs font-semibold uppercase tracking-[0.08em] text-on-surface-variant">
                Khu vực
                <select name="region" class="mt-2 w-full rounded-xl border border-outline-variant bg-surface px-3 py-2 text-sm text-on-background">
                    <option value="">Tất cả</option>
                    @foreach (var region in regions)
                    {
                        <option value="@region.Slug" selected="@(Model.RegionSlug == region.Slug)">@region.Name</option>
                    }
                </select>
            </label>

            <div class="rentals-filter-range" data-filter-range="price">
                <p class="rentals-filter-label">Khoảng giá</p>
                <label>
                    Từ
                    <input name="minPrice" type="number" value="@Model.MinPrice" inputmode="numeric" placeholder="0" />
                </label>
                <label>
                    Đến
                    <input name="maxPrice" type="number" value="@Model.MaxPrice" inputmode="numeric" placeholder="0" />
                </label>
            </div>

            <label class="block text-xs font-semibold uppercase tracking-[0.08em] text-on-surface-variant">
                Sắp xếp
                <select name="sort" class="mt-2 w-full rounded-xl border border-outline-variant bg-surface px-3 py-2 text-sm text-on-background">
                    <option value="" selected="@(string.IsNullOrEmpty(Model.SortBy))">Mới nhất</option>
                    <option value="price_asc" selected="@(Model.SortBy == "price_asc")">Giá tăng dần</option>
                    <option value="price_desc" selected="@(Model.SortBy == "price_desc")">Giá giảm dần</option>
                    <option value="area_desc" selected="@(Model.SortBy == "area_desc")">Diện tích lớn nhất</option>
                    <option value="match_desc" selected="@(Model.SortBy == "match_desc")">Phù hợp nhất</option>
                    @if (Model.IsNearbySort)
                    {
                        <option value="distance_asc" selected>Gần bạn</option>
                    }
                </select>
            </label>

            <div class="rentals-filter-group" data-quick-filter-group="amenities">
                <div class="mb-2 flex items-center justify-between gap-2">
                    <p class="text-xs font-semibold uppercase tracking-[0.08em] text-on-surface-variant">Tiện ích phổ biến</p>
                    @if (advancedAmenities.Count > 0)
                    {
                        <button type="button" class="text-xs font-semibold text-primary" data-rentals-filter-open>Xem thêm</button>
                    }
                </div>
                <div class="flex flex-wrap gap-x-4 gap-y-2 text-sm text-on-background">
                    @foreach (var amenity in quickAmenities)
                    {
                        var isChecked = selectedAmenityIds.Contains(amenity.Id);
                        <label class="inline-flex items-center gap-2">
                            <input type="checkbox" name="amenityIds" value="@amenity.Id" checked="@isChecked" class="h-4 w-4 rounded border-outline-variant text-primary" />
                            @amenity.Name
                        </label>
                    }
                </div>
            </div>

            <div class="rentals-filter-actions">
                <button type="submit" class="inline-flex h-11 items-center justify-center rounded-xl bg-primary px-5 text-sm font-semibold text-white">Áp dụng</button>
                <button type="button" class="inline-flex h-11 items-center justify-center rounded-xl border border-primary px-4 text-sm font-semibold text-primary" data-rentals-filter-open>Bộ lọc thêm</button>
                <button type="button" class="rentals-nearby-action inline-flex h-11 items-center justify-center gap-2 rounded-xl border border-primary px-4 text-sm font-semibold text-primary" data-nearby-rentals>
                    <span class="material-symbols-outlined text-base">near_me</span>
                    Gần bạn
                </button>
                <a asp-action="Rentals" class="inline-flex h-11 items-center justify-center rounded-xl border border-outline-variant px-4 text-sm font-semibold text-on-background">Xóa bộ lọc</a>
            </div>
            <div class="rentals-preference-actions" data-preference-secondary-action>
                <button type="button" class="text-left text-sm font-semibold text-primary" data-preference-save data-is-authenticated="@isAuthenticated.ToString().ToLowerInvariant()">Lưu hồ sơ nhu cầu</button>
                @if (Model.SavedPreference != null)
                {
                    <a href="@Url.Action("Rentals", t.Models.ViewModels.RentalSearchRequest.FromDraft(Model.SavedPreference).ToRouteValues())" class="text-sm font-semibold text-primary" data-preference-apply>Áp dụng hồ sơ đã lưu</a>
                }
            </div>
            <p class="rentals-nearby-status" data-nearby-rentals-status aria-live="polite"></p>
        </form>
    </aside>

    <section class="rentals-results">
    <section class="rentals-results-grid mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3" data-rentals-results-grid>
        @{
            var favIds = (ViewBag.FavoriteIds as HashSet<int>) ?? new HashSet<int>();
        }
        @for (var i = 0; i < Model.Apartments.Count; i++)
        {
            var apartment = Model.Apartments[i];
            var imageUrl = string.IsNullOrWhiteSpace(apartment.CoverImageUrl) ? "/img/rent-1.jpg" : apartment.CoverImageUrl;
            var fxClass = $"d-{(i % 8) + 1}";
            var isFav = favIds.Contains(apartment.Id);

            <div class="rentals-fx @fxClass h-full">
                <article class="listing-card overflow-hidden rounded-3xl border border-outline-variant/70 bg-white shadow-sm h-full">
                    <a asp-action="ApartmentDetail" asp-route-id="@apartment.Id" class="block" data-soft-nav="true">
                        <img src="@imageUrl" alt="@apartment.Title" class="h-52 w-full object-cover" />
                    </a>

                    <div class="space-y-3 px-4 py-4">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-on-surface-variant">@apartment.CategoryName</p>
                                <h2 class="line-clamp-2 font-headline text-lg font-semibold text-on-background">@apartment.Title</h2>
                            </div>
                            @if (isAuthenticated)
                            {
                                <form asp-controller="Favorites" asp-action="Set" method="post" class="inline" data-favorite-form>
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="apartmentId" value="@apartment.Id" />
                                    <input type="hidden" name="shouldBeFavorite" value="@(isFav ? "false" : "true")" />
                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                    <button type="submit" title="@(isFav ? "Bỏ yêu thích" : "Thêm vào yêu thích")"
                                            class="inline-flex h-9 w-9 items-center justify-center rounded-full border @(isFav ? "border-primary bg-primary/10 text-primary" : "border-outline-variant text-on-surface-variant")">
                                        <span class="material-symbols-outlined text-base" style="@(isFav ? "font-variation-settings:'FILL' 1;" : "")">favorite</span>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <a asp-controller="Home" asp-action="Login" asp-route-returnUrl="@returnUrl" title="Đăng nhập để lưu yêu thích"
                                   class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-outline-variant text-on-surface-variant">
                                    <span class="material-symbols-outlined text-base">favorite</span>
                                </a>
                            }
                        </div>

                        <p class="line-clamp-1 text-sm text-on-surface-variant">@apartment.Address</p>
                        @if (apartment.DistanceKm.HasValue)
                        {
                            <p class="rentals-distance-label">@GeoDistance.FormatKm(apartment.DistanceKm.Value)</p>
                        }
                        @if (Model.IsMatchSort && apartment.MatchPercent.HasValue)
                        {
                            <p class="rentals-match-score">@apartment.MatchPercent% phù hợp</p>
                            <ul class="rentals-match-reasons">
                                @foreach (var reason in apartment.MatchReasons.Take(3))
                                {
                                    <li>@reason</li>
                                }
                            </ul>
                        }

                        <div class="grid grid-cols-2 gap-2 rounded-2xl bg-surface-container-low px-3 py-2 text-xs text-on-surface-variant">
                            <div>Diện tích: <strong class="text-on-background">@apartment.Area m2</strong></div>
                            <div>Phòng ngủ: <strong class="text-on-background">@apartment.Bedrooms</strong></div>
                        </div>

                        <div class="flex items-center justify-between">
                            <p class="text-sm font-semibold text-primary">@apartment.Price.ToString("N0") VND/tháng</p>
                            <a asp-action="ApartmentDetail" asp-route-id="@apartment.Id" data-soft-nav="true" class="inline-flex h-9 items-center rounded-lg border border-primary px-3 text-xs font-semibold text-primary">Xem chi tiết</a>
                        </div>
                    </div>
                </article>
            </div>
        }
    </section>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-8 flex justify-center">
            <ul class="flex flex-wrap items-center gap-2">
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li>
                        <a href="@Url.Action("Rentals", Model.Search.ToRouteValues(i))"
                           class="inline-flex h-10 min-w-10 items-center justify-center rounded-lg border px-3 text-sm font-semibold @(i == Model.Page ? "border-primary bg-primary text-white" : "border-outline-variant bg-white text-on-background")">
                            @i
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
    </section>
    </div>

</main>

<aside class="rentals-advanced-drawer" data-rentals-advanced-drawer hidden>
    <div class="rentals-advanced-panel">
        <div class="flex items-center justify-between gap-3">
            <h2 class="font-headline text-xl font-semibold text-primary">Bộ lọc nâng cao</h2>
            <button type="button" class="text-sm font-semibold text-primary" data-rentals-filter-close>Đóng</button>
        </div>

        <div class="rentals-advanced-content">
            <section class="rentals-advanced-group" data-advanced-filter-group="categories">
                <h3>Loại hình</h3>
                <div class="rentals-checkbox-grid">
                    @foreach (var category in categoriesList)
                    {
                        var isChecked = selectedCategoryIds.Contains(category.Id);
                        <label class="preference-checkbox-label">
                            <input type="checkbox" name="categoryIds" value="@category.Id" checked="@isChecked" form="rentals-filter-form" />
                            @category.Name
                        </label>
                    }
                </div>
            </section>

            <section class="rentals-advanced-group" data-advanced-filter-group="housing">
                <h3>Nhu cầu ở</h3>
                <div class="grid gap-3 sm:grid-cols-2">
                    <label>Phòng ngủ tối thiểu <input type="number" name="minBedrooms" min="0" value="@Model.Search.MinBedrooms" form="rentals-filter-form" /></label>
                    <label>Ngày dự kiến vào ở <input type="date" name="availableBy" value="@Model.Search.AvailableBy?.ToString("yyyy-MM-dd")" form="rentals-filter-form" /></label>
                    <label>Nội thất
                        <select name="furnishingLevel" form="rentals-filter-form"><option value="">Không yêu cầu</option><option value="1" selected="@(Model.Search.FurnishingLevel == t.Models.Entities.FurnishingLevel.Basic)">Cơ bản</option><option value="2" selected="@(Model.Search.FurnishingLevel == t.Models.Entities.FurnishingLevel.FullyFurnished)">Đầy đủ</option></select>
                    </label>
                    <label>Chỗ đậu xe
                        <select name="parkingType" form="rentals-filter-form"><option value="">Không yêu cầu</option><option value="1" selected="@(Model.Search.ParkingType == t.Models.Entities.ParkingType.Motorbike)">Xe máy</option><option value="2" selected="@(Model.Search.ParkingType == t.Models.Entities.ParkingType.Car)">Ô tô</option></select>
                    </label>
                    <label class="preference-checkbox-label"><input type="checkbox" name="allowsPets" value="true" checked="@(Model.Search.AllowsPets == true)" form="rentals-filter-form" /> Cho phép nuôi thú cưng</label>
                </div>
            </section>

            <section class="rentals-advanced-group" data-advanced-filter-group="space">
                <h3>Diện tích và tầng</h3>
                <div class="rentals-filter-range" data-filter-range="area">
                    <p class="rentals-filter-label">Diện tích</p>
                    <label>Từ <input type="number" name="minArea" value="@Model.MinArea" form="rentals-filter-form" /></label>
                    <label>Đến <input type="number" name="maxArea" value="@Model.MaxArea" form="rentals-filter-form" /></label>
                </div>
                <div class="mt-3 grid gap-3 sm:grid-cols-2">
                    <label>Tầng tối thiểu <input type="number" name="minFloor" value="@Model.Search.MinFloor" form="rentals-filter-form" /></label>
                    <label>Tầng tối đa <input type="number" name="maxFloor" value="@Model.Search.MaxFloor" form="rentals-filter-form" /></label>
                    <label>Hướng nhà
                        <select name="houseDirection" form="rentals-filter-form">
                            <option value="">Không yêu cầu</option>
                            <option value="0" selected="@(Model.Search.HouseDirection == t.Models.Entities.HouseDirection.East)">Đông</option>
                            <option value="1" selected="@(Model.Search.HouseDirection == t.Models.Entities.HouseDirection.West)">Tây</option>
                            <option value="2" selected="@(Model.Search.HouseDirection == t.Models.Entities.HouseDirection.South)">Nam</option>
                            <option value="3" selected="@(Model.Search.HouseDirection == t.Models.Entities.HouseDirection.North)">Bắc</option>
                            <option value="4" selected="@(Model.Search.HouseDirection == t.Models.Entities.HouseDirection.NorthEast)">Đông Bắc</option>
                            <option value="5" selected="@(Model.Search.HouseDirection == t.Models.Entities.HouseDirection.SouthEast)">Đông Nam</option>
                            <option value="6" selected="@(Model.Search.HouseDirection == t.Models.Entities.HouseDirection.NorthWest)">Tây Bắc</option>
                            <option value="7" selected="@(Model.Search.HouseDirection == t.Models.Entities.HouseDirection.SouthWest)">Tây Nam</option>
                        </select>
                    </label>
                </div>
            </section>

            <section class="rentals-advanced-group" data-advanced-filter-group="location">
                <h3>Tìm quanh địa điểm</h3>
                <p class="rentals-advanced-help">Dùng khi bạn muốn thuê gần cơ quan, trường học hoặc một khu vực cụ thể.</p>
                <div class="grid gap-3 sm:grid-cols-2">
                    <label>Địa điểm muốn ở gần <input type="text" name="preferredAddress" value="@Model.Search.PreferredAddress" placeholder="VD: Ung Văn Khiêm, Bình Thạnh" form="rentals-filter-form" /></label>
                    <label>Bán kính tìm kiếm (km) <input type="number" name="maxDistanceKm" min="1" step="0.5" value="@Model.Search.MaxDistanceKm" form="rentals-filter-form" /></label>
                    <input type="hidden" name="preferredLatitude" value="@FormatCoordinate(Model.Search.PreferredLatitude)" form="rentals-filter-form" />
                    <input type="hidden" name="preferredLongitude" value="@FormatCoordinate(Model.Search.PreferredLongitude)" form="rentals-filter-form" />
                    <div class="preference-map-wrap sm:col-span-2">
                        <div id="preference-address-suggestions" class="preference-address-suggestions" hidden></div>
                        <p id="preference-address-status" class="text-xs text-on-surface-variant" aria-live="polite"></p>
                        <div id="preference-map" class="preference-map" aria-label="Bản đồ vị trí ưu tiên"></div>
                    </div>
                </div>
            </section>

            @if (advancedAmenities.Count > 0)
            {
                <section class="rentals-advanced-group" data-advanced-filter-group="amenities">
                    <h3>Tiện ích khác</h3>
                    <div class="rentals-checkbox-grid">
                        @foreach (var amenity in advancedAmenities)
                        {
                            var isChecked = selectedAmenityIds.Contains(amenity.Id);
                            <label class="preference-checkbox-label"><input type="checkbox" name="amenityIds" value="@amenity.Id" checked="@isChecked" form="rentals-filter-form" /> @amenity.Name</label>
                        }
                    </div>
                </section>
            }

            <section class="rentals-advanced-group" data-advanced-filter-group="lease">
                <h3>Thời hạn thuê</h3>
                <div class="grid gap-3 sm:grid-cols-2">
                    <div class="rentals-lease-control" data-lease-duration-control>
                        <label>Thời hạn thuê tối thiểu</label>
                        <div class="rentals-lease-inputs">
                            <input type="number" min="1" value="@LeaseDisplayValue(Model.Search.MinLeaseMonths)" data-lease-display-value />
                            <select data-lease-display-unit>
                                <option value="months" selected="@(LeaseDisplayUnit(Model.Search.MinLeaseMonths) == "months")">Tháng</option>
                                <option value="years" selected="@(LeaseDisplayUnit(Model.Search.MinLeaseMonths) == "years")">Năm</option>
                            </select>
                        </div>
                        <input type="hidden" name="minLeaseMonths" value="@Model.Search.MinLeaseMonths" data-lease-months-target="minLeaseMonths" form="rentals-filter-form" />
                    </div>
                    <div class="rentals-lease-control" data-lease-duration-control>
                        <label>Thời hạn thuê tối đa</label>
                        <div class="rentals-lease-inputs">
                            <input type="number" min="1" value="@LeaseDisplayValue(Model.Search.MaxLeaseMonths)" data-lease-display-value />
                            <select data-lease-display-unit>
                                <option value="months" selected="@(LeaseDisplayUnit(Model.Search.MaxLeaseMonths) == "months")">Tháng</option>
                                <option value="years" selected="@(LeaseDisplayUnit(Model.Search.MaxLeaseMonths) == "years")">Năm</option>
                            </select>
                        </div>
                        <input type="hidden" name="maxLeaseMonths" value="@Model.Search.MaxLeaseMonths" data-lease-months-target="maxLeaseMonths" form="rentals-filter-form" />
                    </div>
                </div>
            </section>

            <fieldset class="rentals-advanced-group" data-advanced-filter-group="required">
                <legend>Tiêu chí bắt buộc</legend>
                <div class="rentals-checkbox-grid">
                    @foreach (var criterion in t.Models.ViewModels.RentalPreferenceCriteria.Allowed)
                    {
                        <label class="preference-checkbox-label"><input type="checkbox" name="requiredCriteria" value="@criterion" checked="@Model.Search.RequiredCriteria.Contains(criterion)" form="rentals-filter-form" /> @t.Models.ViewModels.RentalPreferenceCriteria.GetLabel(criterion)</label>
                    }
                </div>
            </fieldset>
        </div>

        <div class="rentals-advanced-footer" data-advanced-filter-footer>
            <a asp-action="Rentals" class="inline-flex h-11 items-center justify-center rounded-xl border border-outline-variant px-4 text-sm font-semibold text-on-background">Xóa bộ lọc</a>
            <button type="submit" form="rentals-filter-form" class="inline-flex h-11 items-center justify-center rounded-xl bg-primary px-5 text-sm font-semibold text-white">Áp dụng</button>
        </div>
    </div>
</aside>

<form asp-controller="RentalPreferences" asp-action="Save" method="post" data-preference-save-form hidden>
    @Html.AntiForgeryToken()
    <input type="hidden" name="returnUrl" value="@returnUrl" />
</form>

