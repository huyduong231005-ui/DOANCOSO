@using t.Infrastructure.Localization
@using t.Models.Entities
@model t.Models.ViewModels.MyListingsPageViewModel
@{
    ViewData["Title"] = "Tin của tôi";
    ViewData["BodyClass"] = "luxe-rentals";
    string Pill(ListingStatus s) => s switch
    {
        ListingStatus.Active => "pill pill-success",
        ListingStatus.Draft => "pill pill-neutral",
        ListingStatus.Expired => "pill pill-warning",
        ListingStatus.Hidden => "pill pill-neutral",
        _ => "pill"
    };
}

<partial name="_LuxeTopbar" />

<main class="mx-auto w-full max-w-[1280px] px-4 pb-10 pt-24 sm:px-6 lg:px-8">
    <section class="rounded-3xl border border-outline-variant/60 bg-white/85 px-5 py-5 shadow-sm sm:px-6">
        <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
                <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-on-surface-variant">My Listings</p>
                <h1 class="font-headline text-2xl font-semibold text-primary sm:text-3xl">Tin của tôi</h1>
            </div>
            <div class="flex items-center gap-2">
                <a class="inline-flex h-11 items-center rounded-xl border border-outline-variant px-5 text-sm font-semibold text-on-background" asp-action="Viewings">
                    <span class="material-symbols-outlined" style="font-size:18px;margin-right:6px;">event</span>
                    Lịch hẹn
                </a>
                <a class="inline-flex h-11 items-center rounded-xl bg-primary px-5 text-sm font-semibold text-white" asp-controller="Home" asp-action="PostListing" data-soft-nav="true">
                    <span class="material-symbols-outlined" style="font-size:18px;margin-right:6px;">add</span>
                    Đăng tin mới
                </a>
            </div>
        </div>

        <div class="mt-4 grid gap-3 sm:grid-cols-3">
            <div class="rounded-2xl border border-outline-variant/60 bg-surface-container-low px-4 py-3">
                <p class="text-xs font-semibold uppercase tracking-[0.1em] text-on-surface-variant">Tổng số tin</p>
                <p class="mt-1 text-2xl font-semibold text-on-background">@Model.Total</p>
            </div>
            <div class="rounded-2xl border border-outline-variant/60 bg-surface-container-low px-4 py-3">
                <p class="text-xs font-semibold uppercase tracking-[0.1em] text-on-surface-variant">Đang đăng</p>
                <p class="mt-1 text-2xl font-semibold text-emerald-600">@Model.Active</p>
            </div>
            <div class="rounded-2xl border border-outline-variant/60 bg-surface-container-low px-4 py-3">
                <p class="text-xs font-semibold uppercase tracking-[0.1em] text-on-surface-variant">Đã ẩn</p>
                <p class="mt-1 text-2xl font-semibold text-slate-500">@Model.Hidden</p>
            </div>
        </div>
    </section>

    @if (Model.Items.Count == 0)
    {
        <section class="mt-6 rounded-3xl border border-outline-variant/60 bg-white py-16 text-center">
            <span class="material-symbols-outlined" style="font-size:48px;color:#94a3b8;">inbox</span>
            <h3 class="mt-3 text-lg font-semibold text-on-background">Bạn chưa có tin nào</h3>
            <p class="mt-1 text-sm text-on-surface-variant">Bấm "Đăng tin mới" để tạo tin đầu tiên.</p>
        </section>
    }
    else
    {
        <section class="mt-6 grid gap-4 lg:grid-cols-2">
            @foreach (var item in Model.Items)
            {
                var img = string.IsNullOrWhiteSpace(item.CoverImageUrl) ? "/img/rent-1.jpg" : item.CoverImageUrl;
                <article class="overflow-hidden rounded-3xl border border-outline-variant/70 bg-white shadow-sm">
                    <div class="grid grid-cols-[160px_1fr] gap-4 sm:grid-cols-[200px_1fr]">
                        <a asp-controller="Home" asp-action="ApartmentDetail" asp-route-id="@item.Id" data-soft-nav="true" class="block">
                            <img src="@img" alt="@item.Title" class="h-full w-full object-cover" style="min-height:160px;" />
                        </a>
                        <div class="space-y-2 px-4 py-4">
                            <div class="flex items-start justify-between gap-3">
                                <div>
                                    <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-on-surface-variant">@item.CategoryName</p>
                                    <h2 class="line-clamp-2 font-headline text-lg font-semibold text-on-background">@item.Title</h2>
                                </div>
                                <span class="@Pill(item.Status)">@(item.Status == ListingStatus.Draft ? "Chờ duyệt" : item.Status.Vi())</span>
                            </div>
                            @if (item.Status == ListingStatus.Draft)
                            {
                                <div style="background:#fef3c7;color:#b45309;padding:.4rem .6rem;border-radius:6px;font-size:12px;">
                                    <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle;">hourglass_top</span>
                                    Tin của bạn đang chờ ban quản lý duyệt trước khi hiển thị công khai.
                                </div>
                            }
                            else if (item.Status == ListingStatus.Hidden && !string.IsNullOrWhiteSpace(item.ModerationNote))
                            {
                                <div style="background:#fee2e2;color:#dc2626;padding:.4rem .6rem;border-radius:6px;font-size:12px;">
                                    <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle;">block</span>
                                    <strong>Lý do từ chối:</strong> @item.ModerationNote
                                </div>
                            }
                            <p class="line-clamp-1 text-sm text-on-surface-variant">@item.Address</p>
                            <div class="flex flex-wrap gap-2 text-xs text-on-surface-variant">
                                <span class="rounded-full bg-surface-container-low px-2.5 py-1">@item.Area m²</span>
                                <span class="rounded-full bg-surface-container-low px-2.5 py-1">@item.Bedrooms PN</span>
                                <span class="rounded-full bg-surface-container-low px-2.5 py-1">@item.Bathrooms WC</span>
                                <span class="rounded-full bg-surface-container-low px-2.5 py-1">@item.ViewCount lượt xem</span>
                            </div>
                            <p class="text-sm font-semibold text-primary">@item.Price.ToString("N0") VND/tháng</p>
                            <div class="mt-2 flex flex-wrap items-center gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="inline-flex h-9 items-center rounded-lg border border-primary px-3 text-xs font-semibold text-primary">
                                    <span class="material-symbols-outlined" style="font-size:16px;margin-right:4px;">edit</span>Sửa
                                </a>
                                <form asp-action="Toggle" asp-route-id="@item.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="inline-flex h-9 items-center rounded-lg border border-outline-variant px-3 text-xs font-semibold text-on-background">
                                        <span class="material-symbols-outlined" style="font-size:16px;margin-right:4px;">@(item.Status == ListingStatus.Active ? "visibility_off" : "visibility")</span>
                                        @(item.Status == ListingStatus.Active ? "Ẩn" : "Hiện lại")
                                    </button>
                                </form>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Xoá tin đăng \'@Html.Raw(item.Title.Replace("'", "\\'"))\' ? Hành động này không thể khôi phục.')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="inline-flex h-9 items-center rounded-lg border border-red-300 px-3 text-xs font-semibold text-red-600">
                                        <span class="material-symbols-outlined" style="font-size:16px;margin-right:4px;">delete</span>Xoá
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </article>
            }
        </section>
    }
</main>
