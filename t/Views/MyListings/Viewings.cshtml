@using t.Infrastructure.Localization
@using t.Models.Entities
@model List<t.Models.Entities.ViewingAppointment>
@{
    ViewData["Title"] = "Lịch hẹn xem phòng";
    ViewData["BodyClass"] = "luxe-rentals";
    var status = (ViewingStatus?)ViewBag.Status;
    var pendingCount = (int)(ViewBag.PendingCount ?? 0);
    string Pill(ViewingStatus s) => s switch
    {
        ViewingStatus.Pending => "pill pill-warning",
        ViewingStatus.Confirmed => "pill pill-success",
        ViewingStatus.Cancelled => "pill pill-danger",
        ViewingStatus.Completed => "pill pill-info",
        ViewingStatus.NoShow => "pill pill-neutral",
        _ => "pill"
    };
}

<partial name="_LuxeTopbar" />

<main class="mx-auto w-full max-w-[1280px] px-4 pb-10 pt-24 sm:px-6 lg:px-8">
    <section class="rounded-3xl border border-outline-variant/60 bg-white/85 px-5 py-5 shadow-sm sm:px-6">
        <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
                <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-on-surface-variant">My Bookings</p>
                <h1 class="font-headline text-2xl font-semibold text-primary sm:text-3xl">Lịch hẹn xem phòng</h1>
                @if (pendingCount > 0)
                {
                    <p class="mt-1 text-sm text-amber-600">Có <strong>@pendingCount</strong> lịch hẹn đang chờ bạn xác nhận.</p>
                }
            </div>
            <a asp-action="Index" class="inline-flex h-11 items-center rounded-xl border border-outline-variant px-5 text-sm font-semibold text-on-background">
                <span class="material-symbols-outlined" style="font-size:18px;margin-right:6px;">arrow_back</span>Quay về Tin của tôi
            </a>
        </div>

        <div class="mt-4 flex flex-wrap gap-2">
            <a asp-action="Viewings" class="@(!status.HasValue ? "rounded-full bg-primary px-4 py-2 text-xs font-semibold text-white" : "rounded-full border border-outline-variant px-4 py-2 text-xs font-semibold text-on-background")">Tất cả</a>
            @foreach (var s in Enum.GetValues<ViewingStatus>())
            {
                var active = status == s;
                <a asp-action="Viewings" asp-route-status="@((int)s)" class="@(active ? "rounded-full bg-primary px-4 py-2 text-xs font-semibold text-white" : "rounded-full border border-outline-variant px-4 py-2 text-xs font-semibold text-on-background")">@s.Vi()</a>
            }
        </div>
    </section>

    @if (Model.Count == 0)
    {
        <section class="mt-6 rounded-3xl border border-outline-variant/60 bg-white py-16 text-center">
            <span class="material-symbols-outlined" style="font-size:48px;color:#94a3b8;">event_busy</span>
            <h3 class="mt-3 text-lg font-semibold text-on-background">Chưa có lịch hẹn</h3>
        </section>
    }
    else
    {
        <section class="mt-6 grid gap-4">
            @foreach (var v in Model)
            {
                <article class="rounded-2xl border border-outline-variant/70 bg-white px-5 py-4 shadow-sm">
                    <div class="flex flex-wrap items-start justify-between gap-3">
                        <div>
                            <a asp-controller="Home" asp-action="ApartmentDetail" asp-route-id="@v.ApartmentId" class="text-base font-semibold text-on-background">@v.Apartment.Title</a>
                            <p class="mt-1 text-sm text-on-surface-variant">
                                <strong>@v.ScheduledDate.ToString("dd/MM/yyyy")</strong> · @v.SlotHour.ToString("00"):00 - @((v.SlotHour + 1).ToString("00")):00
                            </p>
                        </div>
                        <span class="@Pill(v.Status)">@v.Status.Vi()</span>
                    </div>

                    <div class="mt-3 grid gap-2 text-sm sm:grid-cols-3">
                        <div><span class="text-on-surface-variant">Khách:</span> <strong>@v.ContactName</strong></div>
                        <div><span class="text-on-surface-variant">SĐT:</span> <strong>@v.ContactPhone</strong></div>
                        <div><span class="text-on-surface-variant">Email:</span> @(string.IsNullOrEmpty(v.ContactEmail) ? "—" : v.ContactEmail)</div>
                    </div>
                    @if (!string.IsNullOrEmpty(v.Note))
                    {
                        <p class="mt-2 rounded-lg bg-surface-container-low px-3 py-2 text-sm text-on-surface-variant"><em>"@v.Note"</em></p>
                    }

                    @if (v.Status == ViewingStatus.Pending || v.Status == ViewingStatus.Confirmed)
                    {
                        <div class="mt-3 flex flex-wrap gap-2">
                            @if (v.Status == ViewingStatus.Pending)
                            {
                                <form asp-action="ConfirmViewing" asp-route-id="@v.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="inline-flex h-9 items-center rounded-lg bg-emerald-600 px-3 text-xs font-semibold text-white">
                                        <span class="material-symbols-outlined" style="font-size:16px;margin-right:4px;">check</span>Xác nhận
                                    </button>
                                </form>
                            }
                            @if (v.Status == ViewingStatus.Confirmed)
                            {
                                <form asp-action="CompleteViewing" asp-route-id="@v.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="inline-flex h-9 items-center rounded-lg border border-primary px-3 text-xs font-semibold text-primary">
                                        <span class="material-symbols-outlined" style="font-size:16px;margin-right:4px;">visibility</span>Đã xem
                                    </button>
                                </form>
                            }
                            <form asp-action="CancelViewing" asp-route-id="@v.Id" method="post" class="d-inline" onsubmit="return confirm('Huỷ lịch hẹn này?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="inline-flex h-9 items-center rounded-lg border border-red-300 px-3 text-xs font-semibold text-red-600">
                                    <span class="material-symbols-outlined" style="font-size:16px;margin-right:4px;">close</span>Huỷ
                                </button>
                            </form>
                        </div>
                    }
                </article>
            }
        </section>
    }
</main>
