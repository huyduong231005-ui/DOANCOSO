@model List<t.Models.Entities.Review>
@using t.Models.Entities
@{
    ViewData["Title"] = "Đánh giá của tôi";
    string StatusLabel(ReviewStatus s) => s switch
    {
        ReviewStatus.Pending => "<span style=\"background:#fef3c7;color:#b45309;padding:2px 8px;border-radius:999px;font-size:11px;\">Đang chờ duyệt</span>",
        ReviewStatus.Approved => "<span style=\"background:#dcfce7;color:#16a34a;padding:2px 8px;border-radius:999px;font-size:11px;\">Đã duyệt</span>",
        ReviewStatus.Rejected => "<span style=\"background:#fee2e2;color:#dc2626;padding:2px 8px;border-radius:999px;font-size:11px;\">Bị từ chối</span>",
        _ => ""
    };
}

<div class="container mx-auto px-4 py-8">
    <div class="mb-6 flex items-center justify-between">
        <h1 class="font-headline text-3xl font-semibold">Đánh giá của tôi</h1>
    </div>

    @if (!Model.Any())
    {
        <div class="rounded-2xl border border-outline-variant/70 bg-white px-6 py-16 text-center">
            <span class="material-symbols-outlined text-6xl text-on-surface-variant/40">rate_review</span>
            <h3 class="mt-4 font-headline text-xl">Bạn chưa viết đánh giá nào</h3>
            <p class="mt-2 text-on-surface-variant">Sau khi thuê căn hộ, bạn có thể viết đánh giá từ trang chi tiết.</p>
        </div>
    }
    else
    {
        <div class="space-y-3">
            @foreach (var r in Model)
            {
                <div class="rounded-xl border border-outline-variant/70 bg-white p-4">
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                        <a asp-controller="Home" asp-action="ApartmentDetail" asp-route-id="@r.ApartmentId" class="font-semibold">@r.Apartment.Title</a>
                        @Html.Raw(StatusLabel(r.Status))
                    </div>
                    <div style="margin-top:.4rem;">
                        @for (var i = 1; i <= 5; i++)
                        {
                            <span class="material-symbols-outlined" style="color:#f59e0b;font-size:18px;">@(i <= r.Rating ? "star" : "star_outline")</span>
                        }
                    </div>
                    <p style="margin-top:.3rem;color:#4b5563;">"@r.Content"</p>
                    <p style="font-size:11px;color:#9ca3af;margin-top:.3rem;">Gửi lúc @r.CreatedAt.ToString("HH:mm dd/MM/yyyy")</p>
                </div>
            }
        </div>
    }
</div>
